{
  "name": "SwarmUI Kohya Training",
  "id": "swarmui_kohya_training",
  "version": "1.0.0",
  "description": "LoRA training integration with Kohya SS for SD 1.5, SDXL, and Flux.1 models",
  "author": "SwarmUI Community",
  "homepage": "https://github.com/bmaltais/kohya_ss",
  "license": "MIT",
  "main_class": "SwarmUI.Builtin_KohyaTrainingExtension.KohyaTrainingExtension",
  "requires": {
    "swarmui_version": "0.9.8"
  },
  "features": [
    "lora-training",
    "kohya-integration",
    "dataset-management",
    "training-monitor"
  ],
  "ui": {
    "pages": [
      {
        "id": "kohya-training",
        "title": "Training",
        "icon": "🎨",
        "path": "training.html"
      }
    ],
    "api_base": "/api/kohya"
  },
  "instructions": {
    "setup": "See README.md for installation",
    "training_folder": "training_data/",
    "output_folder": "Models/Loras/",
    "kohya_install": "https://github.com/bmaltais/kohya_ss"
  }
}
